---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
import BaseHead from '../../components/BaseHead.astro'
import Footer from '../../components/Footer.astro'
import FormattedDate from '../../components/FormattedDate.astro'
import Header from '../../components/Header.astro'
import ThemeInit from '../../components/ThemeInit.astro'
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts'
import { calculateReadingTime } from '../../utils/readingTime'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)

const allCategories = [...new Set(posts.flatMap((p) => p.data.categories ?? []))].sort()
---

<!doctype html>
<html lang="en">
	<head>
		<ThemeInit />
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 1em;
			}
			@media (min-width: 768px) {
				main {
					width: 960px;
				}
			}
			h1 {
				margin-bottom: 1rem;
			}
			.search-wrapper {
				position: relative;
				margin-bottom: 1rem;
			}
			.search-icon {
				position: absolute;
				left: 0.75rem;
				top: 50%;
				transform: translateY(-50%);
				width: 1rem;
				height: 1rem;
				color: rgb(var(--gray));
				pointer-events: none;
			}
			.search-input {
				width: 100%;
				box-sizing: border-box;
				padding: 0.5rem 0.75rem 0.5rem 2.25rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				background: transparent;
				font-family: inherit;
				font-size: 1rem;
				color: rgb(var(--black));
				outline: none;
				transition: border-color 0.15s ease;
			}
			.search-input::placeholder {
				color: rgb(var(--gray));
			}
			.search-input:focus {
				border-color: rgb(var(--accent));
			}
			.filters {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 1.5rem;
			}
			.filter-btn {
				all: unset;
				box-sizing: border-box;
				display: inline-block;
				padding: 0.3rem 0.75rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				font-family: inherit;
				font-size: 0.8rem;
				line-height: 1.5;
				color: rgb(var(--gray));
				cursor: pointer;
				transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease;
			}
			.filter-btn:hover {
				border-color: rgb(var(--accent));
				color: rgb(var(--accent));
			}
			.filter-btn.active {
				background-color: rgb(var(--accent));
				border-color: rgb(var(--accent));
				color: #fff;
			}
			.no-results {
				display: none;
				padding: 2rem 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			ul {
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			ul li:last-child {
				border-bottom: none;
			}
			ul li.hidden {
				display: none;
			}
			ul li a {
				display: flex;
				align-items: flex-start;
				gap: 1rem;
				padding: 0.85rem 0;
				text-decoration: none;
				transition: color 0.2s ease;
			}
			.thumbnail {
				flex-shrink: 0;
				width: 160px;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 8px;
			}
			.post-info {
				display: flex;
				flex: 1;
				flex-direction: column;
				gap: 0.3rem;
				min-width: 0;
			}
			.title {
				margin: 0;
				font-size: 1.1rem;
				font-weight: 600;
				color: rgb(var(--black));
			}
			.meta {
				font-size: 0.875rem;
				color: rgb(var(--gray));
			}
			ul li a:hover .title {
				color: rgb(var(--accent));
			}
			ul li a:hover .meta {
				color: rgb(var(--accent));
			}
			@media (max-width: 480px) {
				.thumbnail {
					width: 100px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>Blog</h1>
				<div class="search-wrapper">
					<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="11" cy="11" r="8"/>
						<line x1="21" y1="21" x2="16.65" y2="16.65"/>
					</svg>
					<input
						class="search-input"
						type="search"
						placeholder="Search posts…"
						aria-label="Search blog posts"
						id="search-input"
					/>
				</div>
				{allCategories.length > 0 && (
					<div class="filters" role="group" aria-label="Filter by category">
						<button class="filter-btn active" data-category="all">All</button>
						{allCategories.map((cat) => (
							<button class="filter-btn" data-category={cat}>{cat}</button>
						))}
					</div>
				)}
				<ul>
					{
						posts.map((post) => (
							<li
								data-categories={JSON.stringify(post.data.categories ?? [])}
								data-title={post.data.title.toLowerCase()}
								data-description={(post.data.description ?? '').toLowerCase()}
							>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											class="thumbnail"
											src={post.data.heroImage}
											width={320}
											height={180}
											alt=""
										/>
									)}
									<span class="post-info">
										<span class="title">{post.data.title}</span>
										<span class="meta">
											<FormattedDate date={post.data.pubDate} /> · {calculateReadingTime(post.body)}
										</span>
									</span>
								</a>
							</li>
						))
					}
				</ul>
				<p class="no-results" id="no-results">No posts found.</p>
			</section>
		</main>
		<Footer />
		<script>
			const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
			const items = document.querySelectorAll<HTMLLIElement>('ul li[data-categories]')
			const searchInput = document.getElementById('search-input') as HTMLInputElement
			const noResults = document.getElementById('no-results') as HTMLParagraphElement
			let active = new Set<string>()
			let query = ''

			function applyFilter() {
				const isAll = active.size === 0

				document.querySelector<HTMLButtonElement>('.filter-btn[data-category="all"]')!
					.classList.toggle('active', isAll)
				buttons.forEach((b) => {
					if (b.dataset.category !== 'all')
						b.classList.toggle('active', active.has(b.dataset.category!))
				})

				let visible = 0
				items.forEach((item) => {
					const cats: string[] = JSON.parse(item.dataset.categories!)
					const matchesCategory = isAll || cats.some((c) => active.has(c))
					const matchesSearch =
						!query ||
						item.dataset.title!.includes(query) ||
						item.dataset.description!.includes(query)
					const show = matchesCategory && matchesSearch
					item.classList.toggle('hidden', !show)
					if (show) visible++
				})

				noResults.style.display = visible === 0 ? 'block' : 'none'

				const url = new URL(location.href)
				isAll ? url.searchParams.delete('categories') : url.searchParams.set('categories', [...active].join(','))
				query ? url.searchParams.set('q', query) : url.searchParams.delete('q')
				history.replaceState(null, '', url)
			}

			const params = new URLSearchParams(location.search)
			const initialCats = params.get('categories')
			if (initialCats) initialCats.split(',').forEach((c) => active.add(decodeURIComponent(c.trim())))
			const initialQ = params.get('q')
			if (initialQ) { query = initialQ.toLowerCase(); searchInput.value = initialQ }
			applyFilter()

			buttons.forEach((btn) => {
				btn.addEventListener('click', () => {
					const cat = btn.dataset.category!
					if (cat === 'all') active.clear()
					else if (active.has(cat)) active.delete(cat)
					else active.add(cat)
					applyFilter()
				})
			})

			searchInput.addEventListener('input', () => {
				query = searchInput.value.trim().toLowerCase()
				applyFilter()
			})
		</script>
	</body>
</html>
