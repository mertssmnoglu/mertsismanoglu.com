---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import BaseHead from '../components/BaseHead.astro'
import Footer from '../components/Footer.astro'
import FormattedDate from '../components/FormattedDate.astro'
import Header from '../components/Header.astro'
import ShareButtons from '../components/ShareButtons.astro'
import ThemeInit from '../components/ThemeInit.astro'
import { SITE_URL } from '../consts'
import { DEFAULT_CONTENT_LICENSE, LICENSES } from '../data/licenses'

type Props = CollectionEntry<'blog'>['data'] & {
  showShareButtons?: boolean
  readingTime?: string
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  smallHeroImage,
  showShareButtons = true,
  readingTime,
  license,
  categories,
} = Astro.props
const canonicalUrl = Astro.url ? new URL(Astro.url.pathname, SITE_URL).toString() : SITE_URL
const licenseData =
  LICENSES[license ?? DEFAULT_CONTENT_LICENSE] ?? LICENSES[DEFAULT_CONTENT_LICENSE]
---

<html lang="en">
	<head>
		<ThemeInit />
		<meta name="fediverse:creator" content="@mertssmnoglu@mastodon.social">
		<BaseHead title={title} description={description} image={heroImage} licenseUrl={licenseData.url} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;	
			}

			.small-hero-image{
				max-width: 400px;
			}
			.hero-image {
				width: 100%;
				margin: 0 auto;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.title hr {
				width: 4rem;
				margin: 1rem auto 0;
			}
			@media (min-width: 768px) {
				.prose {
					width: 960px;
				}
			}
			.categories {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-top: 1rem;
				justify-content: center;
			}
			.category-tag {
				display: inline-block;
				padding: 0.35rem 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				font-size: 0.95rem;
				line-height: 1.5;
				color: rgb(var(--gray));
				text-decoration: none;
				transition: border-color 0.15s ease, color 0.15s ease;
			}
			.category-tag:hover {
				border-color: rgb(var(--accent));
				color: rgb(var(--accent));
			}
			.post-license {
				margin-top: 2rem;
				padding-top: 1rem;
				border-top: 1px solid rgb(var(--gray-light));
				font-size: 0.95rem;
				color: rgb(var(--gray));
			}
			.post-license a {
				color: var(--accent);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class={smallHeroImage ? "small-hero-image hero-image" : "hero-image"}>
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{readingTime && <span> • {readingTime}</span>}
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{categories && categories.length > 0 && (
							<div class="categories">
								{categories.map((cat: string) => (
									<a class="category-tag" href={`/blog/?categories=${encodeURIComponent(cat)}`}>{cat}</a>
								))}
							</div>
						)}
						<hr />
					</div>
					<slot />
					{showShareButtons && <ShareButtons title={title} url={canonicalUrl} />}
					<footer class="post-license">
						<p>
							&copy; 2026 Mert Şişmanoğlu. This post is licensed under <a href={licenseData.url} target="_blank" rel="license noopener noreferrer">
								{licenseData.shortName}
							</a>.
						</p>
					</footer>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
